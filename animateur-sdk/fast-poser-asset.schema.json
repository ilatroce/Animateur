{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Fast Poser Asset",
  "description": "Canonical JSON Schema for fast-poser-asset pose and animation files emitted by the TypeScript SDK and browser tools.",
  "oneOf": [
    {
      "$ref": "#/definitions/PoseAsset"
    },
    {
      "$ref": "#/definitions/AnimationAsset"
    }
  ],
  "definitions": {
    "Vector3": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 3,
      "maxItems": 3
    },
    "Quaternion": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "minItems": 4,
      "maxItems": 4
    },
    "SerializedTransform": {
      "type": "object",
      "required": [
        "position",
        "quaternion"
      ],
      "properties": {
        "position": {
          "$ref": "#/definitions/Vector3"
        },
        "quaternion": {
          "$ref": "#/definitions/Quaternion"
        }
      },
      "additionalProperties": false
    },
    "SerializedPose": {
      "type": "object",
      "patternProperties": {
        "^.+_[0-9]+$": {
          "$ref": "#/definitions/SerializedTransform"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "Scene": {
      "type": "object",
      "required": [
        "characterCount",
        "characterColors"
      ],
      "properties": {
        "characterCount": {
          "type": "integer",
          "minimum": 0
        },
        "characterColors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "KeyframeEasing": {
      "type": "string",
      "enum": [
        "linear",
        "easeInSine",
        "easeOutSine",
        "easeInOutSine",
        "easeInCubic",
        "easeOutCubic",
        "easeInOutCubic"
      ]
    },
    "Keyframe": {
      "type": "object",
      "required": [
        "time",
        "pose"
      ],
      "properties": {
        "time": {
          "type": "number",
          "minimum": 0
        },
        "pose": {
          "$ref": "#/definitions/SerializedPose"
        },
        "easing": {
          "$ref": "#/definitions/KeyframeEasing"
        }
      },
      "additionalProperties": false
    },
    "ArcaneSummonEffect": {
      "type": "object",
      "required": [
        "preset",
        "targetCharacter",
        "startTime",
        "peakTime",
        "endTime",
        "radius",
        "columnHeight",
        "primaryColor",
        "secondaryColor",
        "accentColor",
        "glowColor"
      ],
      "properties": {
        "preset": {
          "const": "arcane-summon"
        },
        "targetCharacter": {
          "type": "integer",
          "minimum": 0
        },
        "startTime": {
          "type": "number",
          "minimum": 0
        },
        "peakTime": {
          "type": "number",
          "minimum": 0
        },
        "endTime": {
          "type": "number",
          "minimum": 0
        },
        "radius": {
          "type": "number",
          "minimum": 1.5,
          "maximum": 6.0
        },
        "columnHeight": {
          "type": "number",
          "minimum": 2.5,
          "maximum": 10.0
        },
        "primaryColor": {
          "type": "string",
          "minLength": 1
        },
        "secondaryColor": {
          "type": "string",
          "minLength": 1
        },
        "accentColor": {
          "type": "string",
          "minLength": 1
        },
        "glowColor": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "PoseAsset": {
      "type": "object",
      "required": [
        "format",
        "version",
        "type",
        "name",
        "savedAt",
        "scene",
        "pose"
      ],
      "properties": {
        "format": {
          "const": "fast-poser-asset"
        },
        "version": {
          "const": 1
        },
        "type": {
          "const": "pose"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "savedAt": {
          "type": "string",
          "format": "date-time"
        },
        "scene": {
          "$ref": "#/definitions/Scene"
        },
        "pose": {
          "$ref": "#/definitions/SerializedPose"
        }
      },
      "additionalProperties": false
    },
    "AnimationAsset": {
      "type": "object",
      "required": [
        "format",
        "version",
        "type",
        "name",
        "savedAt",
        "scene",
        "playbackSpeed",
        "effects",
        "keyframes"
      ],
      "properties": {
        "format": {
          "const": "fast-poser-asset"
        },
        "version": {
          "const": 1
        },
        "type": {
          "const": "animation"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "savedAt": {
          "type": "string",
          "format": "date-time"
        },
        "scene": {
          "$ref": "#/definitions/Scene"
        },
        "playbackSpeed": {
          "type": "number",
          "minimum": 0,
          "exclusiveMinimum": true
        },
        "effects": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/definitions/ArcaneSummonEffect"
            }
          ]
        },
        "keyframes": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Keyframe"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
